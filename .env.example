# THETA local and cloud configuration

# Local PostgreSQL container account.
POSTGRES_USER=theta_user
POSTGRES_PASSWORD=theta_pass

# Backend runtime.
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql://theta_user:theta_pass@localhost:5432/theta

# Redis queue.
REDIS_URL=redis://localhost:6379/0
REDIS_TRAINING_QUEUE=theta:training:jobs

# Object storage. Prefer Cloudflare R2 for production.
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=theta
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PUBLIC_BASE_URL=

# GPU training dispatcher. Use modal_http first; Redis queue can be used by a worker.
GPU_PROVIDER=modal_http
GPU_TRAINING_ENDPOINT=
GPU_TRAINING_TOKEN=
THETA_WORK_DIR=/tmp/theta-worker

# Model embedding provider used by CodeSoul THETA.
EMBEDDING_PROVIDER=cloud
EMBEDDING_CLOUD_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_BASE=
EMBEDDING_API_KEY_ENV=OPENAI_API_KEY
OPENAI_API_KEY=

# Optional AI chat/interpretation provider.
DASHSCOPE_API_KEY=
